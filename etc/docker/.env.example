UID=1000
GID=1000

POSTGRES_IMAGE=postgres:18-alpine
POSTGRES_DB=real_estate_flipping
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_PORT=5432

DB_HOST=db
DB_PORT=5432

BACKEND_NODE_ENV=development
BACKEND_PORT=4000
FRONTEND_PORT=5173

BACKEND_NODE_ENV_PROD=production
BACKEND_PORT_PROD=4000
FRONTEND_PORT_PROD=5173

JWT_SECRET=development-jwt-secret-change-me
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=7d
UPLOAD_PATH=./storage/uploads
CORS_ORIGIN=*
EMAIL_MODE=disabled
EMAIL_FROM=noreply@example.com
AUTO_MIGRATE=true

VITE_API_BASE_URL=http://localhost:4000/api
VITE_USE_MOCKS=false

VITE_API_BASE_URL_PROD=/api
VITE_USE_MOCKS_PROD=false
